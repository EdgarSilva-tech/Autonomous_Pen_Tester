# ── Target application ────────────────────────────────────────────────────────
TARGET_BASE_URL=http://target-app:8000

# ── Agent credentials (must match target-app seed users — see target-app/README.md)
AGENT_USERNAME=alice
AGENT_PASSWORD=Alice#2025
# Leave blank to generate a random new password at runtime (logged at agent.starting)
AGENT_NEW_PASSWORD=

# ── LLM providers (at least OPENAI_API_KEY required) ─────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=          # optional — used as fallback model

# ── LiteLLM Gateway ───────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://litellm-proxy:4000
LITELLM_MASTER_KEY=sk-pentest-master

# ── PostgreSQL (shared, pgvector) ─────────────────────────────────────────────
POSTGRES_USER=pentest
POSTGRES_PASSWORD=pentest
LANGGRAPH_DB_URI=postgresql+asyncpg://pentest:pentest@postgres:5432/langgraph
MEMORY_DB_URI=postgresql+asyncpg://pentest:pentest@postgres:5432/pentest_memory

# ── MCP Servers (optional JSON map) ──────────────────────────────────────────
# MCP_SERVERS={"security-scanner": {"url": "http://mcp-scanner:8080/mcp", "transport": "streamable_http"}}
MCP_SERVERS={}

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=autonomous-pen-tester

# ── Summarise / graph tuning ──────────────────────────────────────────────────
SUMMARY_THRESHOLD=30
SUMMARY_RECENT_KEEP=12

# ── Logging / output ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
REPORT_OUTPUT_PATH=/app/output/report.json
HTTP_TIMEOUT=10
HTTP_MAX_RETRIES=3
