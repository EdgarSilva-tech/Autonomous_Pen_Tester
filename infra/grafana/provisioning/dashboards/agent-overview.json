{
  "title": "Autonomous Pen Tester — Agent Overview",
  "uid": "pentest-agent-overview",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Agent Runs — autonomous-pen-tester",
      "description": "All traces from the agent service. Click any row to open the full span timeline.",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "options": { "dedupStrategy": "none" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"autonomous-pen-tester\" }",
          "tableType": "traces",
          "limit": 20,
          "filters": [],
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "LiteLLM Gateway — LLM Call Traces",
      "description": "One trace per LLM completion. Latency = time the model took to respond.",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "options": { "dedupStrategy": "none" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"litellm\" }",
          "tableType": "traces",
          "limit": 20,
          "filters": [],
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Scraper Service — Health Checks",
      "description": "Playwright scraper spans (health checks run every 10s).",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "options": { "dedupStrategy": "none" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"scraper\" }",
          "tableType": "traces",
          "limit": 20,
          "filters": [],
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Prometheus — Scrape Targets",
      "description": "1 = UP (scrape OK), 0 = DOWN. litellm-proxy is expected to be DOWN (metrics endpoint not yet configured).",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    }

  ]
}
